# ── Captures (never commit pcap files) ───────────────────────────────────────
*.pcap
*.pcapng
*.cap
*.dmp

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Secrets / CA keys ────────────────────────────────────────────────────────
# The CA directory is outside the repo at ~/.sharkpy/ by default,
# but guard against accidental inclusion:
*.key
*.pem
ca.crt
ca/
certs/

# ── Test artefacts ────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── mypy / type-checkers ──────────────────────────────────────────────────────
